# ── Server ────────────────────────────────────────────────
PORT=4000
# Public base URL of this app (used for the Google OAuth redirect).
# Must match an Authorized redirect URI in your Google Cloud OAuth client:
#   <APP_BASE_URL>/auth/google/callback
APP_BASE_URL=http://localhost:4000

# ── Supabase (database + file storage) ────────────────────
# From your Supabase project dashboard.
#
# Settings → Data API → Project URL
SUPABASE_URL=
# Settings → API Keys → Secret keys → "sb_secret_..."
#   SERVER-SIDE ONLY. Bypasses Row Level Security and grants full read/write to
#   the whole database. Never send it to the browser, commit it, or paste it
#   into a chat/issue — revoke and re-mint if that happens.
#   This replaces the legacy service_role JWT; secret keys can be revoked
#   individually without rotating everything else.
#   The frontend calls this Express API for everything EXCEPT the passkey
#   ceremony, which must run in the browser — see SUPABASE_PUBLISHABLE_KEY.
SUPABASE_SECRET_KEY=

# Settings → API Keys → Publishable key ("sb_publishable_...")
#   Safe in client code: it is served to the browser by GET /api/config and is
#   only used for the passkey (WebAuthn) ceremony, which has to run in the
#   browser. It grants nothing on its own — RLS denies `anon` on every table.
#   Leave blank to turn passkeys off; the UI hides them automatically.
SUPABASE_PUBLISHABLE_KEY=
# Settings → Database → Connection string → Transaction pooler (port 6543)
#   Contains your database password. Use the pooler, not a direct connection:
#   direct connections are IPv6-only on Supabase and cap out quickly.
DATABASE_URL=
# Private bucket holding invoice PDFs and org logos. Created by the migration.
SUPABASE_STORAGE_BUCKET=invoices

# ── Google OAuth (for "Send via Gmail") ───────────────────
# Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials
# Enable the Gmail API for the project.
# Add redirect URI: http://localhost:4000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
